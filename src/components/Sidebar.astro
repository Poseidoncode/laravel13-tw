// Determine which sections contain the active page
function isSectionActive(section: typeof sections[number]): boolean {
  return section.items.some(item => currentPath === item.slug);
}
---

<div class="px-4 sidebar-container" data-prefix={prefix}>
  <!-- Navigation -->
  <nav class="space-y-1">
    {
      sections.map((section) => {
        const sectionActive = isSectionActive(section);
        const sectionId = section.title.replace(/\s+/g, '-').toLowerCase();
        const prefixedId = prefix + sectionId;
        return (
          <div class="sidebar-section">
            <button
              class={`sidebar-section-toggle flex items-center justify-between w-full px-3 py-2 rounded-md text-xs font-semibold uppercase tracking-widest transition-colors duration-150 ${
                sectionActive
                  ? 'text-accent bg-accent-light/50'
                  : 'text-text-tertiary hover:text-text-secondary hover:bg-bg-tertiary/50'
              }`}
              aria-expanded={sectionActive ? 'true' : 'false'}
              data-section={prefixedId}
              type="button"
            >
              <span>{section.title}</span>
              <svg
                class="w-3.5 h-3.5 transition-transform duration-200"
                class:list={{ 'rotate-180': sectionActive }}
                fill="none" stroke="currentColor" viewBox="0 0 24 24" stroke-width="2.5"
              >
                <path stroke-linecap="round" stroke-linejoin="round" d="M19.5 8.25l-7.5 7.5-7.5-7.5" />
              </svg>
            </button>
            <div
              class={`sidebar-section-content mt-1 space-y-0.5 ${sectionActive ? '' : 'hidden'}`}
              id={`section-${prefixedId}`}
            >
              {
                section.items.map((item) => {
                  const isActive = currentPath === item.slug;
                  return (
                    <a
                      href={`/docs/${item.slug}`}
                      class={`flex items-center gap-2 px-3 py-1.5 rounded-md text-sm transition-colors duration-150 ${
                        isActive
                          ? 'bg-accent text-white font-medium sidebar-active-item'
                          : 'text-text-secondary hover:text-text-primary hover:bg-bg-tertiary'
                      }`}
                    >
                      {item.title}
                    </a>
                  );
                })
              }
            </div>
          </div>
        );
      })
    }
  </nav>
</div>

<script is:inline>
  (function() {
    const containers = document.querySelectorAll('.sidebar-container');
    const container = containers[containers.length - 1];
    if (!container) return;

    const prefix = container.getAttribute('data-prefix') || '';
    const STORAGE_KEY = 'sidebar-sections' + (prefix ? '-' + prefix.replace(/-$/, '') : '');
    const SCROLL_KEY = 'sidebar-scroll-position' + (prefix ? '-' + prefix.replace(/-$/, '') : '');

    const scrollContainer = container.closest('aside') || container.closest('.overflow-y-auto');

    function loadSavedState() {
      try {
        const saved = sessionStorage.getItem(STORAGE_KEY);
        return saved ? JSON.parse(saved) : {};
      } catch {
        return {};
      }
    }

    function saveState(state) {
      try {
        sessionStorage.setItem(STORAGE_KEY, JSON.stringify(state));
      } catch {}
    }

    const savedState = loadSavedState();
    const toggles = container.querySelectorAll('.sidebar-section-toggle');

    toggles.forEach((button) => {
      const qualifiedId = button.dataset.section;
      const content = container.querySelector(`#section-${qualifiedId}`);
      const icon = button.querySelector('svg');

      if (qualifiedId && qualifiedId in savedState) {
        const shouldExpand = savedState[qualifiedId];
        const currentExpanded = button.getAttribute('aria-expanded') === 'true';

        if (shouldExpand !== currentExpanded) {
          if (content) content.classList.toggle('hidden');
          button.setAttribute('aria-expanded', String(shouldExpand));
          if (icon) icon.classList.toggle('rotate-180');
          button.classList.toggle('text-accent', shouldExpand);
          button.classList.toggle('bg-accent-light/50', shouldExpand);
          button.classList.toggle('text-text-tertiary', !shouldExpand);
        }
      }

      button.addEventListener('click', () => {
        const content = container.querySelector(`#section-${qualifiedId}`);
        const icon = button.querySelector('svg');
        const expanded = button.getAttribute('aria-expanded') === 'true';
        const next = !expanded;

        if (content) content.classList.toggle('hidden');
        button.setAttribute('aria-expanded', String(next));
        if (icon) icon.classList.toggle('rotate-180');

        button.classList.toggle('text-accent', next);
        button.classList.toggle('bg-accent-light/50', next);
        button.classList.toggle('text-text-tertiary', !next);

        const state = loadSavedState();
        state[qualifiedId] = next;
        saveState(state);
      });
    });

    // 恢復滾動位置與監聽滾動事件
    if (scrollContainer) {
      try {
        const savedScrollTop = sessionStorage.getItem(SCROLL_KEY);
        if (savedScrollTop !== null) {
          scrollContainer.scrollTop = parseInt(savedScrollTop, 10);
        } else {
          // 如果沒有保存的滾動位置，則自動滾動到 active 的項目
          const activeLink = container.querySelector('.sidebar-active-item');
          if (activeLink) {
            // 使用 setTimeout 確保 DOM 展開完成後能準確定位
            setTimeout(() => {
              activeLink.scrollIntoView({ block: 'nearest' });
            }, 50);
          }
        }
      } catch (e) {}

      // 監聽滾動，將滾動高度記錄到 sessionStorage
      let scrollTimeout;
      scrollContainer.addEventListener('scroll', () => {
        if (scrollTimeout) {
          clearTimeout(scrollTimeout);
        }
        scrollTimeout = setTimeout(() => {
          try {
            sessionStorage.setItem(SCROLL_KEY, String(scrollContainer.scrollTop));
          } catch (e) {}
        }, 100);
      });
    }
  })();
</script>
