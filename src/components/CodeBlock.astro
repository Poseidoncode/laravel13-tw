---
interface Props {
  code: string;
  lang?: string;
  title?: string;
}

const { code, lang = 'php', title } = Astro.props;
---

<figure class="code-block mb-6 rounded-lg overflow-hidden border border-border group">
  <!-- Optional title bar -->
  {
    title && (
      <figcaption class="flex items-center gap-2 px-4 py-2 text-xs font-medium text-text-tertiary border-b border-border bg-bg-secondary">
        <svg class="w-3.5 h-3.5" fill="none" stroke="currentColor" viewBox="0 0 24 24" stroke-width="2">
          <path stroke-linecap="round" stroke-linejoin="round" d="M10 20l4-16m4 4l4 4-4 4M6 16l-4-4 4-4" />
        </svg>
        <span>{title}</span>
        <span class="ml-auto text-text-tertiary/60">{lang}</span>
      </figcaption>
    )
  }
  <div class="relative">
    <pre class="!mb-0 !border-0 !rounded-none"><code class={`language-${lang}`} set:html={code}></code></pre>
    <button
      class="copy-btn absolute top-2 right-2 z-10 flex items-center gap-1.5 px-2 py-1.5 rounded-md text-xs font-medium opacity-0 group-hover:opacity-100 transition-opacity duration-200 bg-bg-secondary/80 hover:bg-bg-secondary border border-border text-text-secondary hover:text-accent"
      data-code={code.replace(/</g, '&lt;').replace(/>/g, '&gt;').replace(/&/g, '&amp;').replace(/"/g, '&quot;')}
      aria-label="複製程式碼"
      type="button"
    >
      <!-- Clipboard icon -->
      <svg class="copy-icon w-3.5 h-3.5" fill="none" stroke="currentColor" viewBox="0 0 24 24" stroke-width="2">
        <path stroke-linecap="round" stroke-linejoin="round" d="M15.666 3.888A2.25 2.25 0 0013.5 2.25h-3c-1.03 0-1.9.693-2.166 1.638m7.332 0c.055.194.084.4.084.612v0a.75.75 0 01-.75.75H9a.75.75 0 01-.75-.75v0c0-.212.03-.418.084-.612m7.332 0c.646.049 1.288.11 1.927.184 1.1.128 1.907 1.077 1.907 2.185V19.5a2.25 2.25 0 01-2.25 2.25H6.75A2.25 2.25 0 014.5 19.5V6.257c0-1.108.806-2.057 1.907-2.185a48.208 48.208 0 011.927-.184" />
      </svg>
      <!-- Check icon (shown after copy) -->
      <svg class="check-icon w-3.5 h-3.5 hidden" fill="none" stroke="currentColor" viewBox="0 0 24 24" stroke-width="2">
        <path stroke-linecap="round" stroke-linejoin="round" d="M4.5 12.75l6 6 9-13.5" />
      </svg>
      <span class="copy-label">複製</span>
    </button>
  </div>
</figure>

<style>
  .code-block pre {
    border-left: 3px solid var(--clr-code-border);
  }
  .code-block .copy-btn {
    backdrop-filter: blur(4px);
  }
</style>

<script>
  (() => {
    const buttons = document.querySelectorAll('.code-block .copy-btn');
    buttons.forEach((btn) => {
      btn.addEventListener('click', async () => {
        const code = btn.getAttribute('data-code');
        if (!code) return;

        // Decode HTML entities back to raw text for clipboard
        const text = code
          .replace(/&amp;/g, '&')
          .replace(/&lt;/g, '<')
          .replace(/&gt;/g, '>')
          .replace(/&quot;/g, '"')
          .replace(/&#39;/g, "'");

        try {
          await navigator.clipboard.writeText(text);
          showCopied(btn);
        } catch {
          // Fallback for older browsers
          const textarea = document.createElement('textarea');
          textarea.value = text;
          textarea.style.position = 'fixed';
          textarea.style.opacity = '0';
          document.body.appendChild(textarea);
          textarea.select();
          document.execCommand('copy');
          document.body.removeChild(textarea);
          showCopied(btn);
        }
      });
    });

    function showCopied(btn) {
      const icon = btn.querySelector('.copy-icon');
      const check = btn.querySelector('.check-icon');
      const label = btn.querySelector('.copy-label');

      if (icon && check && label) {
        icon.classList.add('hidden');
        check.classList.remove('hidden');
        label.textContent = '已複製';

        setTimeout(() => {
          icon.classList.remove('hidden');
          check.classList.add('hidden');
          label.textContent = '複製';
        }, 2000);
      }
    }
  })();
</script>
