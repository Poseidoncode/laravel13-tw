---
// Search component using Pagefind
---

<div id="search-wrapper" class="relative">
  <!-- Search Button / Trigger -->
  <button
    id="search-trigger"
    class="flex items-center gap-2 w-full px-3 py-2 rounded-lg border border-border text-text-tertiary hover:text-text-secondary hover:border-accent transition-all duration-200 cursor-text bg-transparent"
    aria-label="搜尋文檔"
    type="button"
  >
    <svg class="w-4 h-4 flex-shrink-0" fill="none" stroke="currentColor" viewBox="0 0 24 24" stroke-width="2">
      <path stroke-linecap="round" stroke-linejoin="round" d="M21 21l-6-6m2-5a7 7 0 11-14 0 7 7 0 0114 0z" />
    </svg>
    <span class="text-sm flex-1 text-left">搜尋文檔...</span>
    <kbd class="hidden sm:inline-flex items-center gap-0.5 px-1.5 py-0.5 rounded text-xs font-mono text-text-tertiary border border-border">
      <span>⌘</span>
      <span>K</span>
    </kbd>
  </button>

  <!-- Search Modal -->
  <div
    id="search-modal"
    class="fixed inset-0 z-50 hidden"
    role="dialog"
    aria-modal="true"
    aria-label="搜尋文檔"
  >
    <!-- Backdrop -->
    <div class="fixed inset-0 bg-black/50 backdrop-blur-sm" id="search-backdrop"></div>

    <!-- Search Panel -->
    <div class="fixed top-[12%] left-1/2 -translate-x-1/2 w-full max-w-xl px-4 z-10">
      <div class="bg-surface border border-border rounded-xl shadow-2xl shadow-black/10 overflow-hidden">
        <!-- Search Input -->
        <div class="flex items-center gap-3 px-4 py-3.5 border-b border-border">
          <svg class="w-5 h-5 text-text-tertiary flex-shrink-0" fill="none" stroke="currentColor" viewBox="0 0 24 24" stroke-width="2">
            <path stroke-linecap="round" stroke-linejoin="round" d="M21 21l-6-6m2-5a7 7 0 11-14 0 7 7 0 0114 0z" />
          </svg>
          <input
            type="text"
            id="search-input"
            class="flex-1 bg-transparent text-text-primary placeholder-text-tertiary outline-none text-base"
            placeholder="搜尋文檔內容..."
            autocomplete="off"
            autocorrect="off"
            autocapitalize="off"
            spellcheck="false"
          />
          <button id="search-close" class="flex items-center justify-center w-7 h-7 rounded-md text-text-tertiary hover:text-text-secondary hover:bg-bg-tertiary transition-colors" type="button">
            <svg class="w-4.5 h-4.5" fill="none" stroke="currentColor" viewBox="0 0 24 24" stroke-width="2">
              <path stroke-linecap="round" stroke-linejoin="round" d="M6 18L18 6M6 6l12 12" />
            </svg>
          </button>
        </div>

        <!-- Search Results -->
        <div id="search-results" class="max-h-[55vh] overflow-y-auto">
          <!-- Empty state -->
          <div id="search-empty" class="text-center py-10 text-text-tertiary">
            <svg class="w-10 h-10 mx-auto mb-3 opacity-40" fill="none" stroke="currentColor" viewBox="0 0 24 24" stroke-width="1.5">
              <path stroke-linecap="round" stroke-linejoin="round" d="M21 21l-6-6m2-5a7 7 0 11-14 0 7 7 0 0114 0z" />
            </svg>
            <p class="text-sm">輸入關鍵字開始搜尋</p>
          </div>

          <!-- Loading state -->
          <div id="search-loading" class="hidden text-center py-10 text-text-tertiary">
            <div class="inline-block w-6 h-6 border-2 border-accent border-t-transparent rounded-full animate-spin mb-3"></div>
            <p class="text-sm">搜尋中...</p>
          </div>

          <!-- No results -->
          <div id="search-no-results" class="hidden text-center py-10 text-text-tertiary">
            <svg class="w-10 h-10 mx-auto mb-3 opacity-40" fill="none" stroke="currentColor" viewBox="0 0 24 24" stroke-width="1.5">
              <path stroke-linecap="round" stroke-linejoin="round" d="M9.172 16.172a4 4 0 015.656 0M9 10h.01M15 10h.01M21 12a9 9 0 11-18 0 9 9 0 0118 0z" />
            </svg>
            <p class="text-sm">找不到相關結果</p>
            <p class="text-xs mt-1 opacity-70">嘗試使用不同的關鍵字</p>
          </div>

          <!-- Pagefind not available -->
          <div id="search-init-error" class="hidden text-center py-10 text-text-tertiary">
            <svg class="w-10 h-10 mx-auto mb-3 opacity-40" fill="none" stroke="currentColor" viewBox="0 0 24 24" stroke-width="1.5">
              <path stroke-linecap="round" stroke-linejoin="round" d="M12 9v3.75m9-.75a9 9 0 11-18 0 9 9 0 0118 0zm-9 3.75h.008v.008H12v-.008z" />
            </svg>
            <p class="text-sm">搜尋索引未載入</p>
            <p class="text-xs mt-1 opacity-70">請執行 <code class="font-mono px-1 py-0.5 rounded bg-bg-tertiary">npm run build</code> 後重新整理頁面</p>
          </div>

          <!-- Results list -->
          <div id="search-result-list" class="hidden px-2 py-2 space-y-0.5"></div>
        </div>

        <!-- Search Footer -->
        <div class="flex items-center justify-between px-4 py-2.5 border-t border-border bg-bg-secondary">
          <div class="flex items-center gap-3 text-xs text-text-tertiary">
            <span class="flex items-center gap-1">
              <kbd class="px-1.5 py-0.5 rounded border border-border text-text-tertiary font-mono bg-bg-tertiary">↑↓</kbd>
              <span>導航</span>
            </span>
            <span class="flex items-center gap-1">
              <kbd class="px-1.5 py-0.5 rounded border border-border text-text-tertiary font-mono bg-bg-tertiary">↵</kbd>
              <span>開啟</span>
            </span>
            <span class="flex items-center gap-1">
              <kbd class="px-1.5 py-0.5 rounded border border-border text-text-tertiary font-mono bg-bg-tertiary">Esc</kbd>
              <span>關閉</span>
            </span>
          </div>
          <span class="text-xs text-text-tertiary">Pagefind</span>
        </div>
      </div>
    </div>
  </div>
</div>

<script>
  // Pagefind Search Implementation
  class SearchManager {
    private pagefind: any = null;
    private isOpen = false;
    private selectedIndex = -1;
    private results: any[] = [];

    constructor() {
      this.init();
    }

    private init() {
      const trigger = document.getElementById('search-trigger');
      const closeBtn = document.getElementById('search-close');
      const backdrop = document.getElementById('search-backdrop');
      const input = document.getElementById('search-input') as HTMLInputElement;

      trigger?.addEventListener('click', () => this.open());
      closeBtn?.addEventListener('click', () => this.close());
      backdrop?.addEventListener('click', () => this.close());

      // Keyboard shortcuts
      document.addEventListener('keydown', (e) => {
        if ((e.metaKey || e.ctrlKey) && e.key === 'k') {
          e.preventDefault();
          this.open();
        }
        if (e.key === 'Escape' && this.isOpen) {
          this.close();
        }
        // Focus trap for Tab key when modal is open
        if (e.key === 'Tab' && this.isOpen) {
          const modal = document.getElementById('search-modal');
          if (!modal) return;
          const focusable = modal.querySelectorAll(
            'a[href], button:not([disabled]), input:not([disabled]), [tabindex]:not([tabindex="-1"])'
          );
          if (focusable.length === 0) return;
          const first = focusable[0] as HTMLElement;
          const last = focusable[focusable.length - 1] as HTMLElement;
          if (e.shiftKey && document.activeElement === first) {
            e.preventDefault();
            last.focus();
          } else if (!e.shiftKey && document.activeElement === last) {
            e.preventDefault();
            first.focus();
          }
        }
      });

      // Input handling with debounce
      let debounceTimer: number;
      input?.addEventListener('input', (e) => {
        const target = e.target as HTMLInputElement;
        clearTimeout(debounceTimer);
        debounceTimer = window.setTimeout(() => this.search(target.value), 150);
      });

      // Keyboard navigation
      input?.addEventListener('keydown', (e) => {
        if (e.key === 'ArrowDown') {
          e.preventDefault();
          this.selectNext();
        } else if (e.key === 'ArrowUp') {
          e.preventDefault();
          this.selectPrev();
        } else if (e.key === 'Enter') {
          e.preventDefault();
          this.openSelected();
        }
      });
    }

    private async loadPagefind() {
      if (this.pagefind) return;
      try {
        // Fetch pagefind.js as plain text, then load it via a blob URL
        // to bypass Vite's module transform (which blocks imports from /public/).
        const response = await fetch('/pagefind/pagefind.js');
        const code = await response.text();
        const blob = new Blob([code], { type: 'text/javascript' });
        const blobUrl = URL.createObjectURL(blob);
        try {
          this.pagefind = await import(/* @vite-ignore */ blobUrl);
        } finally {
          URL.revokeObjectURL(blobUrl);
        }
        await this.pagefind.init();
      } catch (e) {
        console.error('Failed to load Pagefind:', e);
        this.pagefind = null;
      }
    }

    private showNotAvailable() {
      const empty = document.getElementById('search-empty');
      const loading = document.getElementById('search-loading');
      const noResults = document.getElementById('search-no-results');
      const list = document.getElementById('search-result-list');
      const initError = document.getElementById('search-init-error');

      empty?.classList.add('hidden');
      loading?.classList.add('hidden');
      noResults?.classList.add('hidden');
      list?.classList.add('hidden');
      initError?.classList.remove('hidden');
    }

    private async open() {
      const modal = document.getElementById('search-modal');
      const input = document.getElementById('search-input') as HTMLInputElement;
      if (!modal || !input) return;

      this.isOpen = true;
      modal.classList.remove('hidden');
      document.body.style.overflow = 'hidden';
      setTimeout(() => input.focus(), 100);
      await this.loadPagefind();
    }

    private close() {
      const modal = document.getElementById('search-modal');
      const input = document.getElementById('search-input') as HTMLInputElement;
      if (!modal) return;

      this.isOpen = false;
      modal.classList.add('hidden');
      document.body.style.overflow = '';
      if (input) input.value = '';
      this.clearResults();
    }

    private async search(query: string) {
      if (!query.trim()) {
        this.clearResults();
        return;
      }

      if (!this.pagefind) await this.loadPagefind();
      if (!this.pagefind) {
        this.showNotAvailable();
        return;
      }

      this.showLoading();

      try {
        const search = await this.pagefind.search(query);
        this.results = search.results || [];
        if (this.results.length === 0) {
          this.showNoResults();
        } else {
          await this.displayResults();
        }
      } catch (e) {
        console.error('Search error:', e);
        this.showNoResults();
      }
    }

    private async displayResults() {
      const list = document.getElementById('search-result-list');
      const empty = document.getElementById('search-empty');
      const loading = document.getElementById('search-loading');
      const noResults = document.getElementById('search-no-results');

      if (!list) return;

      empty?.classList.add('hidden');
      loading?.classList.add('hidden');
      noResults?.classList.add('hidden');
      list.classList.remove('hidden');

      const displayResults = this.results.slice(0, 10);
      let html = '';

      for (let i = 0; i < displayResults.length; i++) {
        const data = await displayResults[i].data();
        html += `
          <a
            href="${data.url}"
            class="search-result-item flex flex-col gap-0.5 px-3 py-2.5 rounded-lg hover:bg-bg-tertiary transition-colors duration-150 ${i === 0 ? 'bg-bg-tertiary' : ''}"
            data-index="${i}"
          >
            <div class="font-medium text-sm text-text-primary">${data.meta?.title || '無標題'}</div>
            <div class="text-xs text-text-tertiary line-clamp-2 leading-relaxed">${data.excerpt || ''}</div>
          </a>
        `;
      }

      list.innerHTML = html;
      this.selectedIndex = 0;

      list.querySelectorAll('.search-result-item').forEach((item) => {
        item.addEventListener('click', (e) => {
          e.preventDefault();
          const href = item.getAttribute('href');
          if (href) {
            this.close();
            window.location.href = href;
          }
        });
      });
    }

    private clearResults() {
      const list = document.getElementById('search-result-list');
      const empty = document.getElementById('search-empty');
      const loading = document.getElementById('search-loading');
      const noResults = document.getElementById('search-no-results');
      const initError = document.getElementById('search-init-error');

      list?.classList.add('hidden');
      loading?.classList.add('hidden');
      noResults?.classList.add('hidden');
      initError?.classList.add('hidden');
      empty?.classList.remove('hidden');
      if (list) list.innerHTML = '';
      this.results = [];
      this.selectedIndex = -1;
    }

    private showLoading() {
      const empty = document.getElementById('search-empty');
      const loading = document.getElementById('search-loading');
      const noResults = document.getElementById('search-no-results');
      const list = document.getElementById('search-result-list');

      empty?.classList.add('hidden');
      noResults?.classList.add('hidden');
      list?.classList.add('hidden');
      loading?.classList.remove('hidden');
    }

    private showNoResults() {
      const empty = document.getElementById('search-empty');
      const loading = document.getElementById('search-loading');
      const noResults = document.getElementById('search-no-results');
      const list = document.getElementById('search-result-list');

      empty?.classList.add('hidden');
      loading?.classList.add('hidden');
      list?.classList.add('hidden');
      noResults?.classList.remove('hidden');
    }

    private selectNext() {
      const items = document.querySelectorAll('.search-result-item');
      if (items.length === 0) return;

      items[this.selectedIndex]?.classList.remove('bg-bg-tertiary');
      this.selectedIndex = (this.selectedIndex + 1) % items.length;
      items[this.selectedIndex]?.classList.add('bg-bg-tertiary');
      items[this.selectedIndex]?.scrollIntoView({ block: 'nearest' });
    }

    private selectPrev() {
      const items = document.querySelectorAll('.search-result-item');
      if (items.length === 0) return;

      items[this.selectedIndex]?.classList.remove('bg-bg-tertiary');
      this.selectedIndex = (this.selectedIndex - 1 + items.length) % items.length;
      items[this.selectedIndex]?.classList.add('bg-bg-tertiary');
      items[this.selectedIndex]?.scrollIntoView({ block: 'nearest' });
    }

    private openSelected() {
      const items = document.querySelectorAll('.search-result-item');
      const selected = items[this.selectedIndex];
      if (selected) {
        const href = selected.getAttribute('href');
        if (href) {
          this.close();
          window.location.href = href;
        }
      }
    }
  }

  // Initialize on DOM ready
  document.addEventListener('DOMContentLoaded', () => {
    new SearchManager();
  });
</script>

<style>
  .line-clamp-2 {
    display: -webkit-box;
    -webkit-line-clamp: 2;
    -webkit-box-orient: vertical;
    overflow: hidden;
  }
</style>
