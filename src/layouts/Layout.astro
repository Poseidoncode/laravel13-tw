---
import '../styles/global.css';
import Search from '../components/Search.astro';

interface Props {
  title: string;
  description?: string;
}

const { title, description = 'Laravel 13.x 繁體中文文檔' } = Astro.props;
---

<!DOCTYPE html>
<html lang="zh-TW">
<head>
  <meta charset="UTF-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1.0" />
  <meta name="description" content={description} />
  <title>{title} | Laravel 13.x 繁體中文文檔</title>

  <!-- ⚡ Theme detection — runs before render to prevent flash ⚡ -->
  <script is:inline>
    (function() {
      var saved = localStorage.getItem('theme') || 'system';
      var prefersDark = window.matchMedia('(prefers-color-scheme: dark)').matches;
      if (saved === 'dark' || (saved === 'system' && prefersDark)) {
        document.documentElement.setAttribute('data-theme', 'dark');
      } else {
        document.documentElement.setAttribute('data-theme', 'light');
      }
    })();
  </script>

  <link rel="preconnect" href="https://fonts.googleapis.com" />
  <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
  <link rel="icon" href="/favicon.svg" type="image/svg+xml" />

</head>
<body>
  <!-- ─── Skip to Content ─── -->
  <a href="#main-content" class="skip-to-content">
    跳到主要內容
  </a>
  <!-- ─── Header ─── -->
  <header class="sticky top-0 z-50 bg-bg-primary/90 backdrop-blur-md border-b border-border">
    <nav class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8 h-16 flex items-center justify-between">
      <!-- Logo -->
      <a href="/" class="flex items-center gap-2.5 no-underline group">
        <span class="text-xl font-bold text-accent group-hover:underline decoration-1 underline-offset-2">
          Laravel
        </span>
        <span class="text-sm text-text-tertiary font-mono font-medium">13.x</span>
        <span class="hidden sm:inline-flex items-center px-2 py-0.5 rounded text-xs font-medium bg-accent/10 text-accent border border-accent/20">
          繁體中文
        </span>
      </a>

      <!-- Right section -->
      <div class="flex items-center gap-2 sm:gap-4">
        <!-- Search (desktop) -->
        <div class="hidden md:block w-64">
          <Search />
        </div>

        <!-- Theme Toggle -->
        <button
          id="theme-toggle"
          class="flex items-center justify-center w-9 h-9 rounded-lg border border-border text-text-secondary hover:text-accent hover:border-accent transition-colors duration-200"
          aria-label="切換主題"
          type="button"
        >
          <!-- Sun icon (dark → light) -->
          <svg id="sun-icon" class="w-4.5 h-4.5 hidden" fill="none" stroke="currentColor" viewBox="0 0 24 24" stroke-width="2">
            <path stroke-linecap="round" stroke-linejoin="round" d="M12 3v2.25m6.364.386l-1.591 1.591M21 12h-2.25m-.386 6.364l-1.591-1.591M12 18.75V21m-4.773-4.227l-1.591 1.591M5.25 12H3m4.227-4.773L5.636 5.636M15.75 12a3.75 3.75 0 11-7.5 0 3.75 3.75 0 017.5 0z" />
          </svg>
          <!-- Moon icon (light → dark) -->
          <svg id="moon-icon" class="w-4.5 h-4.5" fill="none" stroke="currentColor" viewBox="0 0 24 24" stroke-width="2">
            <path stroke-linecap="round" stroke-linejoin="round" d="M21.752 15.002A9.718 9.718 0 0118 15.75c-5.385 0-9.75-4.365-9.75-9.75 0-1.33.266-2.597.748-3.752A9.753 9.753 0 003 11.25C3 16.635 7.365 21 12.75 21a9.753 9.753 0 009.002-5.998z" />
          </svg>
        </button>

        <!-- GitHub -->
        <a
          href="https://github.com/Poseidoncode/laravel13-tw"
          class="flex items-center gap-1.5 text-sm text-text-secondary hover:text-accent transition-colors duration-200 no-underline hover:no-underline"
          target="_blank"
          rel="noopener"
        >
          <svg class="w-4.5 h-4.5" fill="currentColor" viewBox="0 0 24 24">
            <path fill-rule="evenodd" d="M12 2C6.477 2 2 6.484 2 12.017c0 4.425 2.865 8.18 6.839 9.504.5.092.682-.217.682-.483 0-.237-.008-.868-.013-1.703-2.782.605-3.369-1.343-3.369-1.343-.454-1.158-1.11-1.466-1.11-1.466-.908-.62.069-.608.069-.608 1.003.07 1.531 1.032 1.531 1.032.892 1.53 2.341 1.088 2.91.832.092-.647.35-1.088.636-1.338-2.22-.253-4.555-1.113-4.555-4.951 0-1.093.39-1.988 1.029-2.688-.103-.253-.446-1.272.098-2.65 0 0 .84-.27 2.75 1.026A9.564 9.564 0 0112 6.844c.85.004 1.705.115 2.504.337 1.909-1.296 2.747-1.027 2.747-1.027.546 1.379.202 2.398.1 2.651.64.7 1.028 1.595 1.028 2.688 0 3.848-2.339 4.695-4.566 4.943.359.309.678.92.678 1.855 0 1.338-.012 2.419-.012 2.747 0 .268.18.58.688.482A10.019 10.019 0 0022 12.017C22 6.484 17.522 2 12 2z" clip-rule="evenodd" />
          </svg>
          <span class="hidden sm:inline">GitHub</span>
        </a>

        <!-- Mobile Search Trigger -->
        <button
          id="mobile-search-trigger"
          class="md:hidden flex items-center justify-center w-9 h-9 rounded-lg border border-border text-text-secondary hover:text-accent hover:border-accent transition-colors duration-200"
          aria-label="搜尋文檔"
          type="button"
        >
          <svg class="w-4.5 h-4.5" fill="none" stroke="currentColor" viewBox="0 0 24 24" stroke-width="2">
            <path stroke-linecap="round" stroke-linejoin="round" d="M21 21l-6-6m2-5a7 7 0 11-14 0 7 7 0 0114 0z" />
          </svg>
        </button>
      </div>
    </nav>
  </header>

  <!-- ─── Main Content ─── -->
  <main id="main-content" tabindex="-1">
    <slot />
  </main>

  <!-- ─── Footer ─── -->
  <footer class="border-t border-border">
    <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8 py-10">
      <div class="flex flex-col sm:flex-row items-center justify-between gap-4">
        <div class="flex items-center gap-2 text-sm text-text-tertiary">
          <span class="font-medium text-accent">Laravel 13.x</span>
          <span aria-hidden="true">·</span>
          <span>繁體中文文檔</span>
        </div>
        <div class="flex items-center gap-4 text-xs text-text-tertiary">
          <span>社群翻譯專案</span>
          <span aria-hidden="true">·</span>
          <a href="https://laravel.com/docs/13.x" class="text-text-tertiary hover:text-accent no-underline hover:underline" target="_blank" rel="noopener">
            原始文件
          </a>
          <span aria-hidden="true">·</span>
          <a href="https://github.com/Poseidoncode/laravel13-tw" class="text-text-tertiary hover:text-accent no-underline hover:underline" target="_blank" rel="noopener">
            GitHub
          </a>
        </div>
      </div>
    </div>
  </footer>

  <!-- ─── Theme Toggle Script ─── -->
  <script>
    const toggle = document.getElementById('theme-toggle');
    const sunIcon = document.getElementById('sun-icon');
    const moonIcon = document.getElementById('moon-icon');

    function syncIcons(theme) {
      if (theme === 'dark') {
        moonIcon?.classList.add('hidden');
        sunIcon?.classList.remove('hidden');
      } else {
        sunIcon?.classList.add('hidden');
        moonIcon?.classList.remove('hidden');
      }
    }

    // Sync icons on load
    const current = document.documentElement.getAttribute('data-theme');
    if (current) syncIcons(current);

    let themeTransitionId = 0;
    toggle?.addEventListener('click', () => {
      const currentTheme = document.documentElement.getAttribute('data-theme');
      const next = currentTheme === 'dark' ? 'light' : 'dark';
      // Enable smooth theme transition
      document.documentElement.classList.add('theme-transitioning');
      document.documentElement.setAttribute('data-theme', next);
      localStorage.setItem('theme', next);
      syncIcons(next);
      // Remove transition class after animation completes
      // Use a counter to prevent race from rapid toggles
      const thisClick = ++themeTransitionId;
      setTimeout(() => {
        if (thisClick === themeTransitionId) {
          document.documentElement.classList.remove('theme-transitioning');
        }
      }, 300);
    });

    // Listen for system changes
    const mediaQuery = window.matchMedia('(prefers-color-scheme: dark)');
    mediaQuery.addEventListener('change', (e) => {
      const saved = localStorage.getItem('theme');
      if (saved === 'system' || !saved) {
        const next = e.matches ? 'dark' : 'light';
        document.documentElement.setAttribute('data-theme', next);
        syncIcons(next);
      }
    });

    // Mobile search trigger opens the search modal
    document.getElementById('mobile-search-trigger')?.addEventListener('click', () => {
      const trigger = document.getElementById('search-trigger');
      trigger?.click();
    });

    // ─── Copy-to-clipboard for all pre code blocks ───
    function initCopyButtons() {
      // Skip if already enhanced (CodeBlock component handles its own)
      const pres = document.querySelectorAll('article pre, main pre');

      pres.forEach((pre) => {
        // Skip if this pre is inside a .code-block (CodeBlock handles it)
        if (pre.closest('.code-block')) return;
        // Skip if already has a copy button
        if (pre.querySelector('.global-copy-btn')) return;

        const code = pre.querySelector('code');
        if (!code) return;

        const text = code.textContent || '';

        // Create button
        const btn = document.createElement('button');
        btn.className = 'global-copy-btn';
        btn.setAttribute('aria-label', '複製程式碼');
        btn.type = 'button';

        btn.innerHTML = `
          <svg class="w-3.5 h-3.5" fill="none" stroke="currentColor" viewBox="0 0 24 24" stroke-width="2">
            <path stroke-linecap="round" stroke-linejoin="round" d="M15.666 3.888A2.25 2.25 0 0013.5 2.25h-3c-1.03 0-1.9.693-2.166 1.638m7.332 0c.055.194.084.4.084.612v0a.75.75 0 01-.75.75H9a.75.75 0 01-.75-.75v0c0-.212.03-.418.084-.612m7.332 0c.646.049 1.288.11 1.927.184 1.1.128 1.907 1.077 1.907 2.185V19.5a2.25 2.25 0 01-2.25 2.25H6.75A2.25 2.25 0 014.5 19.5V6.257c0-1.108.806-2.057 1.907-2.185a48.208 48.208 0 011.927-.184" />
          </svg>
          <span class="copy-label">複製</span>
        `;

        pre.style.position = 'relative';
        pre.appendChild(btn);

        btn.addEventListener('click', async () => {
          try {
            await navigator.clipboard.writeText(text);
            showCopied(btn);
          } catch {
            // Fallback
            const ta = document.createElement('textarea');
            ta.value = text;
            ta.style.position = 'fixed';
            ta.style.opacity = '0';
            document.body.appendChild(ta);
            ta.select();
            document.execCommand('copy');
            document.body.removeChild(ta);
            showCopied(btn);
          }
        });
      });
    }

    function showCopied(btn) {
      const label = btn.querySelector('.copy-label');
      const icon = btn.querySelector('svg');
      if (!label) return;

      const origText = label.textContent;
      if (icon) icon.style.display = 'none';
      label.textContent = '✓ 已複製';

      setTimeout(() => {
        if (icon) icon.style.display = '';
        label.textContent = origText;
      }, 2000);
    }

    // Run on initial load
    if (document.readyState === 'loading') {
      document.addEventListener('DOMContentLoaded', initCopyButtons);
    } else {
      initCopyButtons();
    }
  </script>
</body>
</html>
